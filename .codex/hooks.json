{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "nixfmt **/*.nix",
            "statusMessage": "Formatting nix-files"
          },
          {
            "type": "command",
            "command": "oxfmt --write . >/dev/null",
            "statusMessage": "Formatting non-nix files"
          }
        ]
      }
    ]
  }
}
